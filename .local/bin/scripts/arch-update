#!/bin/sh

SUDO_COMMANDS='run0 doas sudo'

for command in $SUDO_COMMANDS; do
  if command -v "$command" >/dev/null; then
    sudo_command="$command"
    break
  fi
done

if [ -z "$sudo_command" ]; then
  echo 'No sudo command found. Exiting...'
  exit 1
fi

echo '[1/4] Updating Arch packages...'
"$sudo_command" pacman -Syu
echo

echo '[2/4] Deleting orphaned Arch packages...'
pacman -Qdtq | xargs --no-run-if-empty "$sudo_command" pacman -Rns --noconfirm --
echo

echo '[3/4] Updating Flatpaks...'
flatpak update -y
echo

echo '[4/4] Deleting unused Flatpaks...'
flatpak remove --unused -y
