#!/bin/sh

has_command() {
  command -v "$1" >/dev/null 2>&1
}

if has_command run0; then
  sudo_command='run0 --background='
elif has_command doas; then
  sudo_command=doas
elif has_command sudo; then
  sudo_command=sudo
else
  echo 'No sudo command found. Exiting...'
  exit 1
fi

if has_command flatpak; then
  has_flatpak=true
  step_count=4
else
  has_flatpak=false
  step_count=2
fi

echo "[1/$step_count] Updating Arch packages..."
$sudo_command pacman -Syu

echo
echo "[2/$step_count] Deleting orphaned Arch packages..."
pacman -Qdtq | xargs --no-run-if-empty $sudo_command pacman -Rns --noconfirm --

if $has_flatpak; then
  echo
  echo "[3/$step_count] Updating Flatpaks..."
  flatpak update -y

  echo
  echo "[4/$step_count] Deleting unused Flatpaks..."
  flatpak remove --unused -y
fi
